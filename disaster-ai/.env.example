# ============================================================
# ADCC — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git!
# ============================================================

# ── PostgreSQL Database ──────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/adcc_db

# ── SQL Debugging (set true in development) ──────────────────
SQL_ECHO=false

# ── Google Gemini API ────────────────────────────────────────
# Get from: https://ai.google.dev
GOOGLE_API_KEY=your_gemini_api_key_here

# ── NewsAPI ──────────────────────────────────────────────────
# Get from: https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# ── Twilio (SMS/WhatsApp Alerts) ─────────────────────────────
# Get from: https://www.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ── Sentinel Hub (Satellite Imagery) ─────────────────────────
# Get from: https://www.sentinel-hub.com
SENTINEL_HUB_CLIENT_ID=your_sentinel_client_id
SENTINEL_HUB_CLIENT_SECRET=your_sentinel_client_secret

# ── OpenRouteService (Routing) ───────────────────────────────
# Get from: https://openrouteservice.org
ORS_API_KEY=your_ors_api_key_here

# ── FastAPI Server ───────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
